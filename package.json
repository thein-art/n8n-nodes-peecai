{
  "name": "n8n-nodes-peecai",
  "version": "0.5.0",
  "description": "n8n community node for the Peec AI API — AI Search Analytics for brand visibility, sentiment, and citations",
  "license": "MIT",
  "author": {
    "name": "Tobias Hein",
    "email": "t.hein@artaxo.com"
  },
  "homepage": "https://github.com/thein-art/n8n-nodes-peecai#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/thein-art/n8n-nodes-peecai.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "peecai",
    "peec-ai",
    "ai-search",
    "brand-visibility",
    "ai-analytics"
  ],
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "build": "n8n-node build",
    "dev": "n8n-node dev",
    "lint": "n8n-node lint",
    "lintfix": "n8n-node lint --fix",
    "prepublishOnly": "n8n-node prerelease",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/PeecAiApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/PeecAi/PeecAi.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@n8n/node-cli": "^0.23.0",
    "n8n-workflow": "*",
    "typescript": "^5.7.0",
    "@types/node": "^25.3.5",
    "vitest": "^3.1.0"
  }
}
